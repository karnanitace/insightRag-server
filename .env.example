# Environment Variables — InsightRAG Server
# Copy this to .env and fill in your values

PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/insighrag?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here_change_in_production
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
